{
  "appId": "co.sentinel.dvpn-client",
  "productName": "Sentinel dVPN",
  "copyright": "Copyright © 2026 Sentinel",
  "directories": { "buildResources": "build" },
  "files": ["out/**/*"],
  "icon": "build/icon.png",
  "linux": {
    "target": ["deb", "AppImage", "pacman", "rpm"],
    "icon": "build/icon.png",
    "extraResources": [
      {"from": "dist-helper/sentinel-helper","to": "sentinel-helper"}
    ]
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.utilities",
    "icon": "build/icon.png",
    "extraResources": [
      { "from": "dist-helper/sentinel-helper-mac", "to": "sentinel-helper"}
    ]

  },
  "win": {
    "target": ["nsis"],
    "icon": "build/icon.ico",
    "extraResources": [
      {"from": "dist-helper/sentinel-helper.exe", "to": "sentinel-helper.exe"}
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": true,
    "include": "build/installer.nsh"
  },
  "deb": {
    "afterInstall": "build/linux/postinst.sh",
    "afterRemove":  "build/linux/postrm.sh"
  },
  "rpm": {
    "afterInstall": "build/linux/postinst.sh",
    "afterRemove":  "build/linux/postrm.sh"
  },
  "pacman": {
    "afterInstall": "build/linux/postinst.sh",
    "afterRemove":  "build/linux/postrm.sh"
  }
}
